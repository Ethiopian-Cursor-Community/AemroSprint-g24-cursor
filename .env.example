# Required for Auth.js / NextAuth (min 32 chars). Also required for Playwright e2e tests.
# Generate: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# AI Models (Google Gemini for free tier)
GOOGLE_GENERATIVE_AI_API_KEY=****

# Cursor SDK key (powers Deep Dive topic explanations + chat fallback)
# Get one at https://cursor.com/dashboard/cloud-agents
CURSOR_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres (Neon: paste connection string ONLY — not `psql "..."`)
# Example shape: postgresql://user:pass@host/dbname?sslmode=require
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
