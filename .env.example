# Required for Auth.js / NextAuth (min 32 chars). Also required for Playwright e2e tests.
# Generate: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# Cursor SDK key — powers every AI-generated response in the app (chat,
# summaries, roadmaps, quizzes, emergency plans, deep dives, artifacts).
# Get one at https://cursor.com/dashboard/cloud-agents
CURSOR_API_KEY=****

# Cursor SDK runtime: "local" (dev) or "cloud" (production / Vercel).
# Defaults to "local" on dev machines and "cloud" on Vercel (VERCEL=1)
# because Vercel's serverless filesystem is read-only.
CURSOR_SDK_RUNTIME=local

# Required only when CURSOR_SDK_RUNTIME=cloud — the agent clones this repo.
# Point it at the same repo as the app, e.g.:
#   https://github.com/Ethiopian-Cursor-Community/AemroSprint-g24-cursor.git
CURSOR_SDK_REPO_URL=

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres (Neon: paste connection string ONLY — not `psql "..."`)
# Example shape: postgresql://user:pass@host/dbname?sslmode=require
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
